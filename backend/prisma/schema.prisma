generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  reviews   Review[]
  createdAt DateTime @default(now())
}

model Course {
  id          String   @id @default(uuid())
  title       String
  description String
  platform    String
  url         String
  rating      Float?
  difficulty  String?
  reviews     Review[]
  createdAt   DateTime @default(now())
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  text      String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  course    Course   @relation(fields: [courseId], references: [id])
  courseId  String
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}
